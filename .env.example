# Nexus — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs. .env n'est jamais versionné.

# APIs avec clé — SANS préfixe VITE_ : ces clés restent côté serveur (proxies dev
# + fonctions serverless Vercel) et ne sont JAMAIS inlinées dans le bundle client.
FRED_API_KEY=
ALPHA_VANTAGE_KEY=
POLYGON_KEY=
QUANDL_KEY=
TWELVE_DATA_KEY=

# SEC EDGAR — pas de clé, mais un User-Agent avec contact est requis par la SEC.
SEC_USER_AGENT=

# Anthropic (Claude API) — clé secrète, jamais exposée au client (proxy /api/claude)
ANTHROPIC_KEY=

# Make.com — URL du webhook des alertes (étape 9). Secrète : reste côté serveur
# (proxy /api/alert), jamais dans le bundle. Optionnelle : sans elle, les alertes
# fonctionnent quand même en notification intra-app.
MAKE_WEBHOOK_URL=

# Supabase — publiques par design (l'anon key est protégée par les règles RLS),
# donc préfixées VITE_ pour être disponibles dans le client.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
